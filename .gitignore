# Foundry
cache/
out/
# Ignore per-run artifacts but keep the canonical deploy record per chain.
# (Must exclude *contents*, not the directory itself — a file inside an
# excluded directory can never be re-included by a negation.)
broadcast/*/*/*
!broadcast/*/*/run-latest.json
.forge-snapshots/

# Node
node_modules/
dist/
*.tsbuildinfo
.npm/

# Env
.env
.env.*
!.env.example

# Editor
.vscode/
.idea/
*.swp
.DS_Store

# Keys / secrets (belt-and-suspenders)
*.pem
*.key
