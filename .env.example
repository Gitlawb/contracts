# Copy to .env and fill in. Never commit .env.

# EOA that deploys contracts and pays gas. Becomes `owner` on
# GitlawbBounty / GitlawbStaking / GitlawbNodeStaking / GitlawbFeeDistributor.
DEPLOYER_PRIVATE_KEY=

# Base RPC URL.
#   Mainnet: https://mainnet.base.org
#   Sepolia: https://sepolia.base.org
GITLAWB_CHAIN_RPC_URL=https://sepolia.base.org

# $GITLAWB ERC20 address. Mainnet: 0x5F980Dcfc4c0fa3911554cf5ab288ed0eb13DBa3
# On Sepolia, DeployTestnet.s.sol deploys a mock and wires it automatically.
GITLAWB_TOKEN=0x5F980Dcfc4c0fa3911554cf5ab288ed0eb13DBa3

# Basescan API key for --verify on mainnet deploys.
BASESCAN_API_KEY=
